# ─────────────────────────────────────────────────────────
#  KanFlow — Environment Variables Template
#  คัดลอกไฟล์นี้เป็น .env แล้วใส่ค่าจริงของคุณ
#  ไฟล์นี้ commit ขึ้น Git ได้ (ไม่มีค่า sensitive)
# ─────────────────────────────────────────────────────────

# Django Core
SECRET_KEY=your-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Email (Gmail SMTP)
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password-here
DEFAULT_FROM_EMAIL=KanFlow <your-email@gmail.com>
